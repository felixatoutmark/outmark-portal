# Supabase project (create at https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE_NEVER_EXPOSE_TO_CLIENT

# Direct DB connection for migrations / seeding (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Resend (https://resend.com → API Keys)
RESEND_API_KEY=re_...
RESEND_FROM=Outmark <hello@outmark.ca>

# App
NEXT_PUBLIC_APP_URL=https://portal.outmark.ca
NEXT_PUBLIC_ADMIN_EMAIL=felix@outmark.ca

# Cal.com — set when ready (placeholder used in dev)
NEXT_PUBLIC_CAL_LINK=outmark/shoot-day
